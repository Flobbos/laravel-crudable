{
    "name": "flobbos/laravel-crudable",
    "description": "A Laravel package for saving time on crud operations",
    "keywords": [
        "laravel",
        "crud",
        "database"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Alexej Krzewitzki",
            "email": "alexej@helloo.it",
            "homepage": "http://helloo.it"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "11.*|12.*|13.*",
        "cocur/slugify": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Flobbos\\Crudable\\CrudableServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Flobbos\\Crudable\\": "src/Crudable/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Flobbos\\Crudable\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
